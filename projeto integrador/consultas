from sqlalchemy import func # func: importa funções do SQLAlchemy (nesse código não está sendo utilizada).
from db import SessionLocal # SessionLocal: cria uma sessão para conectar e realizar operações no banco de dados.
from models import usuário, Resposta # usuário e Resposta: são os modelos (tabelas) do banco de dados.

def salvar_resposta(dados): # Essa função recebe um dicionário chamado dados com as informações do formulário e salva tudo no banco.
    db = SessionLocal()  # Cria uma sessão para poder inserir e consultar dados.
    try:  # Garante que, ao final da execução, a conexão será fechada, mesmo que ocorra algum erro.
        usuário = usuário(   # Cria um novo registro da tabela Usuário usando os valores recebidos.
            vinculo_senac=dados.get("vinculo_senac"), 
            faixa_etaria=dados.get("faixa_etaria"),     
            renda_mensal=dados.get("renda_mensal"), 
        )
        resposta = Resposta( # Cria um registro da tabela Resposta contendo todas as respostas do formulário.
            gastos_mensais=dados.get("gastos_mensais"),
            salario_investido=dados.get("salario_investido"),
            percade_investimento=dados.get("percade_investimento"),
            uso_do_dinheiro=dados.get("uso_do_dinheiro"),
            patrimonio_investido=dados.get("patrimonio_investido"),
            opcoes=dados.get("opcoes"),
            gastos_por_impulso=dados.get("gastos_por_impulso"),
            decisoes_financeiras=dados.get("decisoes_financeiras"),
            tempo_investido=dados.get("tempo_investido"),
            Reserva_Emergencial=dados.get("Reserva_Emergencial"),
            Mercado_financeiro=dados.get("Mercado_financeiro"),
            Produtos_Financeiros=dados.get("Produtos_Financeiros"),
            Perfil_risco=dados.get("perfil_risco"),
            perfil_usuário=usuário,
        )
        db.add(resposta) # Adiciona o objeto à sessão.
        db.commit() # Confirma a gravação dos dados no banco.
        db.refresh(resposta) # Atualiza o objeto com os dados gerados pelo banco, como o ID.
        return resposta.id # Retorna o identificador da resposta que acabou de ser salva.
    finally: db.close() # Fecha a sessão com o banco de dados, independentemente de ocorrer erro ou não.

def buscar_resposta(resposta_id): # Recebe o ID de uma resposta e procura esse registro no banco.
    db = SessionLocal() # Conecta ao banco de dados.
    try:
        return db.get(Resposta, resposta_id) # Procura na tabela Resposta pelo registro cujo ID seja igual a resposta_id.
    finally: 
        db.close() # Encerra a conexão com o banco.
